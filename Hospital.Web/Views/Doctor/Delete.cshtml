@model Hospital.Domain.Entities.Doctor

@{
    ViewData["Title"] = "Delete Doctor";
}

<div class="glass-card">
    <h1 class="text-danger mb-4">Delete Doctor</h1>
    <h3 class="mb-4">Are you sure you want to delete this?</h3>
    <div>
        <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Specialization)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Specialization)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ConsultationFee)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ConsultationFee)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="DoctorId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
</div>
